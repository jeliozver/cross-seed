{
	"compilerOptions": {
		"outDir": "./dist",
		"rootDir": "./",
		"target": "es2022",
		"lib": ["es2023"],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"sourceMap": true,
		"declaration": true,
		"declarationMap": true,
		"strictNullChecks": true,
		"types": ["node"],
		"composite": true,
		"noEmit": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo"
	},
	"include": ["./**/*.ts"]
}
