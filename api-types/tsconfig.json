{
	"compilerOptions": {
		"composite": true,
		"types": [],
		"target": "es2022",
		"lib": ["es2023"],
		"module": "nodenext",
		"moduleResolution": "nodenext",
		"allowImportingTsExtensions": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"sourceMap": true,
		"strictNullChecks": true,
		"noEmit": true,
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.tsbuildinfo",
		"baseUrl": ".",
		"paths": {
			"@cross-seed/backend/*": ["../cross-seed/dist/*"]
		}
	},
	"references": [{ "path": "../cross-seed/tsconfig.build.json" }],
	"include": ["./src/**/*"]
}
